<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="700" prefWidth="1200" styleClass="root-pane" stylesheets="@../css/admin-dashboard.css" xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/17.0.12" fx:controller="client.controller.AdminDashboardController">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="15" styleClass="top-bar">
            <padding>
                <Insets bottom="15" left="20" right="20" top="15" />
            </padding>

            <Label styleClass="logo-label" text="BidZone Admin" />
            <Region HBox.hgrow="ALWAYS" />

            <TextField prefWidth="250" promptText="Search..." />
            <Label text="Admin" />
            <Button onAction="#handleLogout" styleClass="logout-btn" text="Logout" />
        </HBox>
    </top>

    <left>
        <VBox prefWidth="220" spacing="10" styleClass="sidebar">
            <padding>
                <Insets bottom="20" left="10" right="10" top="20" />
            </padding>

            <Button maxWidth="Infinity" onAction="#showDashboard" text="Dashboard" />
            <Button maxWidth="Infinity" onAction="#showUsers" text="Users" />
            <Button maxWidth="Infinity" onAction="#showAuctions" text="Auctions" />
            <Button maxWidth="Infinity" onAction="#showProducts" text="Products" />
            <Button maxWidth="Infinity" onAction="#showReports" text="Reports" />
            <Button maxWidth="Infinity" onAction="#showSettings" text="Settings" />
        </VBox>
    </left>

    <center>
        <VBox spacing="20" styleClass="content-area">
            <padding>
                <Insets bottom="20" left="20" right="20" top="20" />
            </padding>

            <HBox spacing="20">
                <VBox prefWidth="180" styleClass="stat-card">
                    <Label styleClass="stat-number" text="120" />
                    <Label text="Total Users" />
                </VBox>

                <VBox prefWidth="180" styleClass="stat-card">
                    <Label styleClass="stat-number" text="18" />
                    <Label text="Active Auctions" />
                </VBox>

                <VBox prefWidth="180" styleClass="stat-card">
                    <Label styleClass="stat-number" text="54" />
                    <Label text="Finished Auctions" />
                </VBox>

                <VBox prefWidth="180" styleClass="stat-card">
                    <Label styleClass="stat-number" text="73" />
                    <Label text="Products" />
                </VBox>
            </HBox>

            <Label styleClass="section-title" text="Recent Auctions" />

            <TableView fx:id="auctionTable" prefHeight="250">
                <columns>
                    <TableColumn prefWidth="120" text="Auction ID" />
                    <TableColumn prefWidth="220" text="Product" />
                    <TableColumn prefWidth="150" text="Seller" />
                    <TableColumn prefWidth="150" text="Current Price" />
                    <TableColumn prefWidth="120" text="Status" />
                    <TableColumn prefWidth="180" text="End Time" />
                </columns>
            </TableView>

            <Label styleClass="section-title" text="System Alerts" />

            <ListView fx:id="alertList" prefHeight="150" />
        </VBox>
    </center>

</BorderPane>
