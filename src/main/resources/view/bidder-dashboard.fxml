<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<?import javafx.geometry.Insets?>
<BorderPane prefHeight="900.0" prefWidth="1400.0" styleClass="root-container" stylesheets="@../css/bidder-dashboard.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="client.controller.BidderDashboardController">
   <top>
      <HBox alignment="CENTER_LEFT" prefHeight="90.0" styleClass="top-bar">
         <padding>
            <Insets bottom="20" left="30" right="30" top="20" />
         </padding>

         <children>
            <HBox alignment="CENTER_LEFT" spacing="12">
               <children>
                  <StackPane prefHeight="42" prefWidth="42" styleClass="logo-box">
                     <children>
                        <Label styleClass="logo-icon" text="⚖" />
                     </children>
                  </StackPane>
                  <Label styleClass="logo-text" text="BidZone" />
               </children>
            </HBox>

            <Region HBox.hgrow="ALWAYS" />

            <HBox alignment="CENTER_RIGHT" spacing="18">
               <children>

                  <VBox alignment="CENTER_RIGHT" spacing="4">
                     <children>
                        <Label fx:id="bidderNameLabel" text="" styleClass="user-name"/>
                        <Label text="BIDDER" styleClass="user-role"/>
                     </children>
                  </VBox>

                  <VBox alignment="CENTER_LEFT" spacing="4" styleClass="wallet-box">
                     <children>
                        <Label text="Ví của tôi" styleClass="wallet-title"/>
                        <Label fx:id="walletBalanceLabel" text="\$0.00" styleClass="wallet-balance"/>
                     </children>
                  </VBox>

               </children>
            </HBox>
            <Button mnemonicParsing="false" onAction="#handleLogout" styleClass="logout-button" text="🚪" />
         </children>
      </HBox>
   </top>
   <center>
      <ScrollPane fitToWidth="true" prefHeight="200.0" prefWidth="200.0" BorderPane.alignment="CENTER">
         <content>
            <VBox prefHeight="200.0" prefWidth="100.0" spacing="24.0" styleClass="content-wrapper">
               <children>
                  <VBox prefHeight="200.0" prefWidth="100.0" spacing="6.0" styleClass="hero-section">
                     <children>
                        <Label styleClass="page-title" text="Phiên đấu giá đang diễn ra">
                           <font>
                              <Font size="17.0" />
                           </font></Label>
                        <Label contentDisplay="BOTTOM" prefHeight="133.0" prefWidth="560.0" styleClass="page-subtitle" text="Cạnh tranh ngay để sở hữu những sản phẩm tốt nhất" textFill="#1b1818">
                           <graphic>
                              <TilePane hgap="30.0" prefColumns="3" prefHeight="200.0" prefWidth="200.0" vgap="30.0">
                                 <children>
                                    <VBox prefHeight="200.0" prefWidth="100.0">
                                       <children>
                                          <StackPane prefHeight="150.0" prefWidth="200.0" />
                                       </children>
                                    </VBox>
                                 </children></TilePane>
                           </graphic>
                        </Label>
                        <HBox alignment="CENTER_LEFT" spacing="12.0">
                           <children>
                              <Button fx:id="refreshButton" mnemonicParsing="false" onAction="#handleRefresh" styleClass="secondary-button" text="Làm mới" />
                           </children>
                        </HBox>
                     </children></VBox>
                  <FlowPane fx:id="auctionContainer" hgap="28.0" prefHeight="200.0" prefWidth="200.0" prefWrapLength="1200.0" vgap="28.0" />
               </children>
            </VBox>
         </content>
      </ScrollPane>
   </center>
</BorderPane>
