<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="900.0" prefWidth="1400.0" styleClass="root-container" stylesheets="@../css/bidder-dashboard.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="client.controller.BidderDashboardController">
   <left>
      <VBox prefWidth="360.0" spacing="28.0" styleClass="sidebar" BorderPane.alignment="CENTER">
         <children>
            <HBox alignment="CENTER_LEFT" spacing="14.0">
               <children>
                  <Label styleClass="sidebar-logo-icon" text="⚖" />
                  <Label styleClass="sidebar-logo-text" text="BidZone" />
               </children>
            </HBox>

            <VBox spacing="16.0" VBox.vgrow="ALWAYS">
               <children>
                  <Label styleClass="sidebar-title" text="Bắt đầu hành trình đấu giá của bạn" wrapText="true" />
                  <Label styleClass="sidebar-subtitle" text="Theo dõi phiên đấu giá, đặt giá realtime và quản lý ví của bạn trên hệ thống." wrapText="true" />

                  <VBox spacing="14.0" styleClass="sidebar-feature-box">
                     <children>
                        <Label styleClass="sidebar-feature" text="✓ Tham gia phiên đấu giá realtime" />
                        <Label styleClass="sidebar-feature" text="✓ Theo dõi giá và thời gian còn lại" />
                        <Label styleClass="sidebar-feature" text="✓ Nạp ví nhanh bằng popup" />
                     </children>
                  </VBox>
               </children>
            </VBox>

            <VBox spacing="12.0" styleClass="sidebar-menu">
               <children>
                  <Button fx:id="homeButton" maxWidth="Infinity" mnemonicParsing="false" onAction="#handleShowHome" styleClass="sidebar-menu-button-active" text="⌂  Trang chủ" />
                  <Button fx:id="wonAuctionsButton" maxWidth="Infinity" mnemonicParsing="false" onAction="#handleShowWonAuctions" styleClass="sidebar-menu-button" text="🏆 Phiên đấu giá đã thắng" />
                  <Button fx:id="interestedAuctionsButton" maxWidth="Infinity" mnemonicParsing="false" onAction="#handleShowInterestedAuctions" styleClass="sidebar-menu-button" text="❤  Phiên đấu giá quan tâm" />
                  <Button maxWidth="Infinity" mnemonicParsing="false" onAction="#handleChangePassword" styleClass="sidebar-menu-button" text="🔒  Đổi mật khẩu" />
                  <Button maxWidth="Infinity" mnemonicParsing="false" onAction="#handleLogout" styleClass="sidebar-logout-button" text="🚪  Đăng xuất" />
               </children>
            </VBox>
         </children>
      </VBox>
   </left>

   <center>
      <VBox styleClass="dashboard-main">
         <children>
            <HBox alignment="CENTER_LEFT" spacing="16.0" styleClass="top-header">
               <children>
                  <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                     <children>
                        <Label styleClass="page-title" text="Trang chủ đấu giá" />
                        <Label styleClass="page-subtitle" text="Chọn một sản phẩm để xem chi tiết và tham gia đấu giá." />
                     </children>
                  </VBox>
                  <VBox alignment="CENTER_RIGHT" spacing="4.0">
                     <children>
                        <Label fx:id="bidderNameLabel" styleClass="user-name" text="Bidder" />
                        <Label styleClass="user-role" text="BIDDER" />
                     </children>
                  </VBox>
               </children>
            </HBox>

            <ScrollPane fitToWidth="true" styleClass="main-scroll" VBox.vgrow="ALWAYS">
               <content>
                  <VBox spacing="22.0" styleClass="content-wrapper">
                     <children>
                        <HBox alignment="CENTER_LEFT" spacing="18.0" styleClass="hero-section">
                           <children>
                              <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                                 <children>
                                    <Label fx:id="sectionTitleLabel"
                                           styleClass="section-title"
                                           text="Phiên đấu giá đang diễn ra" />

                                    <Label fx:id="sectionSubtitleLabel"
                                           styleClass="section-subtitle"
                                           text="Cạnh tranh ngay để sở hữu những sản phẩm tốt nhất." />
                                 </children>
                              </VBox>

                              <HBox alignment="CENTER_LEFT" spacing="12.0">
                                 <children>
                                    <VBox alignment="CENTER" prefHeight="42.0" prefWidth="188.0" spacing="4.0" styleClass="bidder-wallet-mini-card">
                                       <children>
                                          <Label styleClass="bidder-wallet-mini-title" text="Ví của tôi" />
                                          <Label fx:id="bidderWalletBalanceLabel" styleClass="bidder-wallet-mini-balance" text="\$0.00" />
                                       </children>
                                    </VBox>

                                    <Button mnemonicParsing="false" onAction="#handleOpenWalletPopup" styleClass="wallet-open-button" text="💳 Mở ví" />
                                 </children>
                              </HBox>


                           </children>
                        </HBox>
                        <StackPane>
                           <children>
                              <FlowPane fx:id="auctionContainer" hgap="28.0" prefWrapLength="980.0" vgap="28.0" />
                              <VBox fx:id="interestedAuctionPane" managed="false" spacing="16.0" visible="false">
                                 <children>
                                    <HBox alignment="CENTER_LEFT" spacing="12.0">
                                       <children>
                                          <TextField fx:id="interestedSearchField" prefWidth="240.0" promptText="Tìm phiên đấu giá..." />
                                          <ComboBox fx:id="interestedStatusFilterBox" prefWidth="170.0" promptText="Trạng thái" />
                                          <Button mnemonicParsing="false" onAction="#handleRefreshInterested" styleClass="wallet-open-button" text="Làm mới" />
                                       </children>
                                    </HBox>
                                    <TableView fx:id="interestedAuctionTable" prefHeight="520.0">
                                       <columns>
                                          <TableColumn fx:id="interestIdColumn" prefWidth="105.0" text="Auction ID" />
                                          <TableColumn fx:id="interestProductColumn" prefWidth="190.0" text="Product" />
                                          <TableColumn fx:id="interestSellerColumn" prefWidth="145.0" text="Seller" />
                                          <TableColumn fx:id="interestLeaderColumn" prefWidth="145.0" text="Leader" />
                                          <TableColumn fx:id="interestPriceColumn" prefWidth="145.0" text="Current Price" />
                                          <TableColumn fx:id="interestStatusColumn" prefWidth="120.0" text="Status" />
                                          <TableColumn fx:id="interestEndTimeColumn" prefWidth="170.0" text="End Time" />
                                       </columns>
                                    </TableView>
                                 </children>
                              </VBox>
                           </children>
                        </StackPane>
                     </children>
                  </VBox>
               </content>
            </ScrollPane>
         </children>
      </VBox>
   </center>
</BorderPane>
