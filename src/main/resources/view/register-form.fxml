<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox alignment="CENTER" prefHeight="669.0" prefWidth="629.0" spacing="15" styleClass="register-container" stylesheets="@register-form.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="client.controller.RegisterFormController">

    <Label style="-fx-font-size: 24px;" styleClass="title-label" text="Register" />

    <TextField fx:id="username" promptText="Username" />
    <PasswordField fx:id="password" promptText="Password" />
    <PasswordField fx:id="confirmPassword" promptText="Confirm Password" />

    <Button onAction="#handleRegister" text="Register" />

    <Hyperlink onAction="#goToLogin" styleClass="subtitle-label" text="Already have account? Login" />

</VBox>
