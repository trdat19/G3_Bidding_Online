<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="900.0" prefWidth="1400.0" styleClass="root-container" stylesheets="@../css/seller-dashboard.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="client.controller.SellerDashboardController">
    <left>
        <VBox prefWidth="360.0" spacing="28.0" styleClass="sidebar" BorderPane.alignment="CENTER">
            <children>
                <HBox alignment="CENTER_LEFT" spacing="14.0">
                    <children>
                        <Label styleClass="sidebar-logo-icon" text="⚖" />
                        <Label styleClass="sidebar-logo-text" text="BidZone" />
                    </children>
                </HBox>

                <VBox spacing="16.0" VBox.vgrow="ALWAYS">
                    <children>
                        <Label styleClass="sidebar-title" text="Quản lý gian hàng đấu giá của bạn" wrapText="true" />
                        <Label styleClass="sidebar-subtitle" text="Thêm sản phẩm, gửi yêu cầu duyệt và thiết lập phiên đấu giá sau khi admin chấp nhận." wrapText="true" />

                        <VBox spacing="14.0" styleClass="sidebar-feature-box">
                            <children>
                                <Label styleClass="sidebar-feature" text="✓ Quản lý sản phẩm của Seller" />
                                <Label styleClass="sidebar-feature" text="✓ Theo dõi trạng thái duyệt" />
                                <Label styleClass="sidebar-feature" text="✓ Tạo phiên đấu giá sau khi được duyệt" />
                            </children>
                        </VBox>
                    </children>
                </VBox>

                <VBox spacing="12.0" styleClass="sidebar-menu">
                    <children>
                        <Button fx:id="productsButton" maxWidth="Infinity" mnemonicParsing="false" onAction="#handleShowProducts" styleClass="sidebar-menu-button-active" text="⌂  Sản phẩm" />
                        <Button fx:id="approvedAuctionsButton" maxWidth="Infinity" mnemonicParsing="false" onAction="#handleShowApprovedAuctions" styleClass="sidebar-menu-button" text="▦  Quản lý sản phẩm đấu giá" />
                        <Button maxWidth="Infinity" mnemonicParsing="false" onAction="#handleOpenSellerWalletPopup" styleClass="sidebar-menu-button" text="💰  Ví của tôi" />
                        <Button maxWidth="Infinity" mnemonicParsing="false" onAction="#handleChangePassword" styleClass="sidebar-menu-button" text="🔒  Đổi mật khẩu" />
                        <Button maxWidth="Infinity" mnemonicParsing="false" onAction="#handleLogout" styleClass="sidebar-logout-button" text="🚪  Đăng xuất" />
                    </children>
                </VBox>
            </children>
        </VBox>
    </left>

    <center>
        <VBox styleClass="dashboard-main">
            <children>
                <HBox alignment="CENTER_LEFT" spacing="16.0" styleClass="top-header">
                    <children>
                        <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                            <children>
                                <Label styleClass="page-title" text="Trang Seller" />
                                <Label styleClass="page-subtitle" text="Quản lý sản phẩm và phiên đấu giá của bạn." />
                            </children>
                        </VBox>
                        <VBox alignment="CENTER" prefHeight="65.0" prefWidth="148.0" spacing="4.0">
                            <children>
                                <Label fx:id="sellerNameLabel" styleClass="user-name" text="Seller" />
                                <Label styleClass="user-role" text="SELLER" />
                            </children>
                        </VBox>
                        <VBox alignment="CENTER" prefHeight="14.0" prefWidth="169.0" spacing="4.0" styleClass="seller-wallet-mini-card">
                            <children>
                                <Label styleClass="seller-wallet-mini-title" text="Ví bán hàng" />
                                <Label fx:id="sellerWalletBalanceLabel" styleClass="seller-wallet-mini-balance" text="\$0.00" />
                            </children>
                        </VBox>
                        <Button mnemonicParsing="false" onAction="#handleOpenSellerWalletPopup" styleClass="primary-button" text="Mở ví" />
                    </children>
                </HBox>

                <ScrollPane fitToWidth="true" styleClass="main-scroll" VBox.vgrow="ALWAYS">
                    <content>
                        <VBox spacing="22.0" styleClass="content-wrapper">
                            <children>
                                <HBox alignment="CENTER_LEFT" spacing="18.0" styleClass="hero-section">
                                    <children>
                                        <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                                            <children>
                                                <Label fx:id="sectionTitleLabel" styleClass="section-title" text="Sản phẩm của bạn" />
                                                <Label fx:id="sectionSubtitleLabel" styleClass="section-subtitle" text="Thêm mới, chỉnh sửa, xóa hoặc tạo đấu giá tùy theo trạng thái sản phẩm." />
                                            </children>
                                        </VBox>
                                        <Button mnemonicParsing="false" onAction="#handleAddProduct" styleClass="primary-button" text="+ Thêm sản phẩm" />
                                        <Button mnemonicParsing="false" onAction="#handleRefresh" styleClass="secondary-button" text="Làm mới" />
                                    </children>
                                </HBox>

                                <StackPane>
                                    <children>
                                        <FlowPane fx:id="productContainer" hgap="28.0" prefWrapLength="980.0" vgap="18.0" />
                                        <VBox fx:id="approvedAuctionPane" managed="false" spacing="14.0" visible="false">
                                            <children>
                                                <TableView fx:id="approvedAuctionTable" prefHeight="560.0" styleClass="seller-auction-table">
                                                    <columns>
                                                        <TableColumn fx:id="auctionIdColumn" prefWidth="90.0" text="Mã phiên" />
                                                        <TableColumn fx:id="auctionProductColumn" prefWidth="175.0" text="Tên sản phẩm" />
                                                        <TableColumn fx:id="auctionStartPriceColumn" prefWidth="125.0" text="Giá khởi điểm" />
                                                        <TableColumn fx:id="auctionCurrentPriceColumn" prefWidth="125.0" text="Giá hiện tại" />
                                                        <TableColumn fx:id="auctionStartTimeColumn" prefWidth="170.0" text="Bắt đầu" />
                                                        <TableColumn fx:id="auctionEndTimeColumn" prefWidth="170.0" text="Kết thúc" />
                                                        <TableColumn fx:id="auctionStatusColumn" prefWidth="120.0" text="Trạng thái" />
                                                        <TableColumn fx:id="auctionBidCountColumn" prefWidth="100.0" text="Số lượt bid" />
                                                    </columns>
                                                </TableView>
                                            </children>
                                        </VBox>
                                    </children>
                                </StackPane>
                            </children>
                        </VBox>
                    </content>
                </ScrollPane>
            </children>
        </VBox>
    </center>
</BorderPane>
