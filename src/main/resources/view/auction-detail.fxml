<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="client.controller.AuctionDetailController"
            stylesheets="@../css/auction-detail.css"
            styleClass="root">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="18">
            <padding>
                <Insets top="18" right="42" bottom="18" left="42"/>
            </padding>

            <Button text="← Back"
                    onAction="#handleBack"
                    styleClass="back-button"/>

            <Label text="Chi tiết phiên đấu giá"
                   styleClass="page-title"/>

            <Region HBox.hgrow="ALWAYS"/>

            <Label fx:id="statusLabel"
                   text="OPEN"
                   styleClass="status-open"/>
        </HBox>
    </top>

    <center>
        <VBox spacing="24">
            <padding>
                <Insets top="28" right="42" bottom="36" left="42"/>
            </padding>

            <!-- HERO SECTION -->
            <HBox spacing="28" styleClass="hero-card">

                <StackPane prefWidth="430"
                           prefHeight="330"
                           styleClass="hero-image">
                    <Label text="Image"
                           styleClass="image-placeholder"/>
                </StackPane>

                <VBox spacing="16" HBox.hgrow="ALWAYS">

                    <Label fx:id="productNameLabel"
                           text="Product Name"
                           styleClass="product-name"/>

                    <Label fx:id="categoryLabel"
                           text="Category"
                           styleClass="product-category"/>

                    <Separator/>

                    <Label text="Mô tả sản phẩm"
                           styleClass="product-description-title"/>

                    <Label fx:id="descriptionLabel"
                           text="Description"
                           wrapText="true"
                           styleClass="product-description"/>

                    <Region VBox.vgrow="ALWAYS"/>

                    <Label text="Giá hiện tại"
                           styleClass="field-label"/>

                    <Label fx:id="currentPriceLabel"
                           text="0"
                           styleClass="hero-price"/>

                    <Label text="Thời gian còn lại"
                           styleClass="field-label"/>

                    <Label fx:id="timeLeftLabel"
                           text="00:00:00"
                           styleClass="hero-countdown"/>

                    <HBox spacing="12">
                        <Button text="Tham gia đấu giá"
                                onAction="#handleJoinAuction"
                                styleClass="primary-button"/>

                        <Button text="Quay lại danh sách"
                                onAction="#handleBack"
                                styleClass="secondary-button"/>
                    </HBox>

                </VBox>
            </HBox>

            <!-- STAT GRID -->
            <GridPane hgap="16" vgap="16" styleClass="stat-grid">
                <columnConstraints>
                    <ColumnConstraints percentWidth="33.33"/>
                    <ColumnConstraints percentWidth="33.33"/>
                    <ColumnConstraints percentWidth="33.33"/>
                </columnConstraints>

                <VBox spacing="6"
                      styleClass="stat-box"
                      GridPane.rowIndex="0"
                      GridPane.columnIndex="0">
                    <Label text="GIÁ KHỞI ĐIỂM"
                           styleClass="stat-label"/>
                    <Label fx:id="startPriceLabel"
                           text="0"
                           styleClass="stat-value"/>
                </VBox>

                <VBox spacing="6"
                      styleClass="stat-box"
                      GridPane.rowIndex="0"
                      GridPane.columnIndex="1">
                    <Label text="NGƯỜI DẪN ĐẦU"
                           styleClass="stat-label"/>
                    <Label fx:id="leadingBidderLabel"
                           text="None"
                           styleClass="stat-value"/>
                </VBox>

                <VBox spacing="6"
                      styleClass="stat-box"
                      GridPane.rowIndex="0"
                      GridPane.columnIndex="2">
                    <Label text="SỐ LƯỢT BID"
                           styleClass="stat-label"/>
                    <Label fx:id="bidCountLabel"
                           text="0 bids"
                           styleClass="stat-value"/>
                </VBox>

                <VBox spacing="6"
                      styleClass="stat-box"
                      GridPane.rowIndex="1"
                      GridPane.columnIndex="0">
                    <Label text="BẮT ĐẦU"
                           styleClass="stat-label"/>
                    <Label fx:id="startTimeLabel"
                           text="--/--/---- --:--"
                           styleClass="stat-value"/>
                </VBox>

                <VBox spacing="6"
                      styleClass="stat-box"
                      GridPane.rowIndex="1"
                      GridPane.columnIndex="1">
                    <Label text="KẾT THÚC"
                           styleClass="stat-label"/>
                    <Label fx:id="endTimeLabel"
                           text="--/--/---- --:--"
                           styleClass="stat-value"/>
                </VBox>

                <VBox spacing="6"
                      styleClass="stat-box"
                      GridPane.rowIndex="1"
                      GridPane.columnIndex="2">
                    <Label text="TRẠNG THÁI"
                           styleClass="stat-label"/>
                    <Label text="Theo dõi realtime"
                           styleClass="stat-value"/>
                </VBox>

            </GridPane>

        </VBox>
    </center>

</BorderPane>