<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>


<ScrollPane fitToWidth="true"
            fitToHeight="true"
            hbarPolicy="NEVER"
            vbarPolicy="AS_NEEDED"
            styleClass="auction-detail-scroll"
            stylesheets="@../css/auction-detail.css"
            xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="client.controller.AuctionDetailController">
   <content>
      <BorderPane styleClass="auction-detail-root">
      
          <top>
              <HBox alignment="CENTER_LEFT" spacing="18">
                  <padding>
                      <Insets bottom="18" left="42" right="42" top="18" />
                  </padding>
      
                  <Button onAction="#handleBack" styleClass="back-button" text="✕ Đóng" />
      
                  <Label styleClass="page-title" text="Chi tiết phiên đấu giá" />
      
                  <Region HBox.hgrow="ALWAYS" />
      
                  <Label fx:id="statusLabel" styleClass="status-open" text="OPEN" />
              </HBox>
          </top>
      
          <center>
              <VBox spacing="24">
                  <padding>
                      <Insets bottom="36" left="42" right="42" top="28" />
                  </padding>
      
                  <!-- HERO SECTION -->
                  <HBox spacing="28" styleClass="hero-card">
      
                      <StackPane prefHeight="330" prefWidth="430" styleClass="hero-image">
                          <ImageView fx:id="productImageView" fitHeight="330" fitWidth="430" preserveRatio="true" smooth="true" />
                          <Label fx:id="imagePlaceholderLabel" styleClass="image-placeholder" text="Ảnh sản phẩm" />
                      </StackPane>
      
                      <VBox spacing="16" HBox.hgrow="ALWAYS">
      
                          <Label fx:id="productNameLabel" styleClass="product-name" text="Product Name" />
      
                          <Label fx:id="categoryLabel" styleClass="product-category" text="Category" />
      
                          <Separator />
      
                          <Label styleClass="product-description-title" text="Mô tả sản phẩm" />
      
                          <Label fx:id="descriptionLabel" styleClass="product-description" text="Description" wrapText="true" />
      
                          <Region VBox.vgrow="ALWAYS" />
      
                          <Label styleClass="field-label" text="Giá hiện tại" />
      
                          <Label fx:id="currentPriceLabel" styleClass="hero-price" text="0" />
      
                          <Label styleClass="field-label" text="Thời gian còn lại" />
      
                          <Label fx:id="timeLeftLabel" styleClass="hero-countdown" text="00:00:00" />
      
                          <HBox spacing="12">
                              <Button onAction="#handleJoinAuction" styleClass="primary-button" text="Tham gia đấu giá" />
      
                              <Button onAction="#handleBack" styleClass="secondary-button" text="Đóng" />
                          </HBox>
      
                      </VBox>
                  </HBox>
      
                  <!-- STAT GRID -->
                  <GridPane hgap="16" styleClass="stat-grid" vgap="16">
                      <columnConstraints>
                          <ColumnConstraints percentWidth="33.33" />
                          <ColumnConstraints percentWidth="33.33" />
                          <ColumnConstraints percentWidth="33.33" />
                      </columnConstraints>
      
                      <VBox spacing="6" styleClass="stat-box" GridPane.columnIndex="0" GridPane.rowIndex="0">
                          <Label styleClass="stat-label" text="GIÁ KHỞI ĐIỂM" />
                          <Label fx:id="startPriceLabel" styleClass="stat-value" text="0" />
                      </VBox>
      
                      <VBox spacing="6" styleClass="stat-box" GridPane.columnIndex="1" GridPane.rowIndex="0">
                          <Label styleClass="stat-label" text="NGƯỜI DẪN ĐẦU" />
                          <Label fx:id="leadingBidderLabel" styleClass="stat-value" text="None" />
                      </VBox>
      
                      <VBox spacing="6" styleClass="stat-box" GridPane.columnIndex="2" GridPane.rowIndex="0">
                          <Label styleClass="stat-label" text="SỐ LƯỢT BID" />
                          <Label fx:id="bidCountLabel" styleClass="stat-value" text="0 bids" />
                      </VBox>
      
                      <VBox spacing="6" styleClass="stat-box" GridPane.columnIndex="0" GridPane.rowIndex="1">
                          <Label styleClass="stat-label" text="BẮT ĐẦU" />
                          <Label fx:id="startTimeLabel" styleClass="stat-value" text="--/--/---- --:--" />
                      </VBox>
      
                      <VBox spacing="6" styleClass="stat-box" GridPane.columnIndex="1" GridPane.rowIndex="1">
                          <Label styleClass="stat-label" text="KẾT THÚC" />
                          <Label fx:id="endTimeLabel" styleClass="stat-value" text="--/--/---- --:--" />
                      </VBox>
      
                      <VBox spacing="6" styleClass="stat-box" GridPane.columnIndex="2" GridPane.rowIndex="1">
                          <Label styleClass="stat-label" text="TRẠNG THÁI" />
                          <Label styleClass="stat-value" text="Theo dõi realtime" />
                      </VBox>
                  <rowConstraints>
                     <RowConstraints />
                     <RowConstraints />
                  </rowConstraints>
      
                  </GridPane>
      
              </VBox>
          </center>
      
      </BorderPane>
   </content>
</ScrollPane>
