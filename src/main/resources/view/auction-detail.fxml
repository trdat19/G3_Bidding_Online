<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="700.0" prefWidth="1100.0" stylesheets="@../css/auction-detail.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="client.controller.AuctionDetailController">
    <children>
        <VBox prefHeight="700.0" prefWidth="1100.0" spacing="20.0" styleClass="root-container" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <padding>
                <Insets bottom="25" left="30" right="30" top="25" />
            </padding>
            <HBox alignment="CENTER_LEFT" spacing="12">
                <Button fx:id="backButton" onAction="#handleBack" styleClass="back-button" text="← Back" />
                <Label styleClass="page-title" text="Thông tin đấu giá" />
                <Region HBox.hgrow="ALWAYS" />
                <Label fx:id="statusLabel" styleClass="status-running" text="RUNNING" />
            </HBox>
            <HBox spacing="25.0" VBox.vgrow="ALWAYS">
                <VBox alignment="TOP_CENTER" spacing="15.0" styleClass="image-card">
                    <padding>
                        <Insets bottom="20" left="20" right="20" top="20" />
                    </padding>

                    <Label styleClass="section-title" text="Ảnh sản phẩm" />
                    <ImageView fx:id="productImageView" fitHeight="260" fitWidth="360" preserveRatio="true" styleClass="image-box" />
                    <Label styleClass="hint-text" text="(MacBook Pro M3 Max)" />
                </VBox>
                <VBox spacing="18.0" HBox.hgrow="ALWAYS">
                    <VBox spacing="12.0" styleClass="info-card">
                        <padding>
                            <Insets bottom="22" left="22" right="22" top="22" />
                        </padding>

                        <Label fx:id="productNameLabel" styleClass="product-name" text="MacBook Pro M3 Max" />
                        <Label fx:id="categoryLabel" styleClass="product-category" text="Category: Electronics" />

                        <Separator />

                        <Label styleClass="section-title" text="Mô tả sản phẩm" />
                        <Label fx:id="descriptionLabel" prefHeight="31.0" prefWidth="582.0" styleClass="product-description-title" wrapText="true" />
                    </VBox>
                    <VBox spacing="14.0" styleClass="info-card">
                        <padding>
                            <Insets bottom="22" left="22" right="22" top="22" />
                        </padding>

                        <Label styleClass="section-title" text="Thông tin đấu giá" />

                        <HBox spacing="20">
                            <VBox spacing="6" styleClass="current-price" HBox.hgrow="ALWAYS">
                                <Label styleClass="current-price" text="Giá khởi điểm" />
                                <Label fx:id="startPriceLabel" styleClass="current-price" text="20,000,000 VND" />
                            </VBox>

                            <VBox prefHeight="44.0" prefWidth="221.0" spacing="6" styleClass="price-value" HBox.hgrow="ALWAYS">
                                <Label styleClass="current-price" text="Giá cao nhất hiện tại" />
                                <Label fx:id="currentPriceLabel" prefHeight="31.0" prefWidth="202.0" styleClass="current-price" text="25,500,000 VND" />
                            </VBox>
                        </HBox>

                        <HBox spacing="20">
                            <VBox spacing="6" styleClass="field-label" HBox.hgrow="ALWAYS">
                                <Label styleClass="small-label" text="Người dẫn đầu" />
                                <Label fx:id="leadingBidderLabel" styleClass="normal-value" text="user123" />
                            </VBox>

                            <VBox prefHeight="18.0" prefWidth="118.0" spacing="6" styleClass="field-label" HBox.hgrow="ALWAYS">
                                <Label prefHeight="17.0" prefWidth="101.0" styleClass="small-label" text="Bid Count" />
                                <Label fx:id="bidCountLabel" styleClass="normal-value" text="12 bids" />
                            </VBox>
                        </HBox>

                        <HBox spacing="20">
                            <VBox spacing="6" styleClass="field-label" HBox.hgrow="ALWAYS">
                                <Label styleClass="small-label" text="Thời gian bắt đầu" />
                                <Label fx:id="startTimeLabel" styleClass="normal-value" text="18/04/2026 19:00" />
                            </VBox>

                            <VBox spacing="6" styleClass="field-label" HBox.hgrow="ALWAYS">
                                <Label prefHeight="18.0" prefWidth="130.0" styleClass="small-label" text="Thời gian kết thúc" />
                                <Label fx:id="endTimeLabel" styleClass="normal-value" text="18/04/2026 20:00" />
                            </VBox>
                        </HBox>

                        <VBox spacing="6" styleClass="countdown-value">
                            <Label styleClass="small-label" text="Thời gian còn lại" />
                            <Label fx:id="timeLeftLabel" styleClass="countdown-text" text="00:42:18" />
                        </VBox>
                    </VBox>

                    <!-- Action buttons -->
                    <HBox alignment="CENTER_RIGHT" spacing="15">
                        <Button fx:id="joinAuctionButton" onAction="#handleJoinAuction" styleClass="primary-button" text="Tham gia" />
                        <Button fx:id="backToListButton" onAction="#handleBack" styleClass="secondary-button" text="Quay lại" />
                    </HBox>

                </VBox>
            </HBox>
        </VBox>
    </children>
</AnchorPane>
