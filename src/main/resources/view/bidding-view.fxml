<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.chart.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<BorderPane styleClass="root" stylesheets="@../css/bidding-view.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="client.controller.BiddingViewController">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="18" styleClass="top-bar">
            <padding>
                <Insets bottom="18" left="28" right="28" top="18" />
            </padding>

            <Button onAction="#handleBack" styleClass="back-button" text="← Back" />
            <Label styleClass="title" text="Đấu giá trực tiếp" />
            <Region HBox.hgrow="ALWAYS" />
            <Label fx:id="statusTextLabel" styleClass="status-running" text="RUNNING" />
        </HBox>
    </top>

    <center>
        <HBox alignment="TOP_CENTER" spacing="28">
            <padding>
                <Insets bottom="36" left="42" right="42" top="28" />
            </padding>

            <!-- LEFT PANEL -->
            <VBox maxWidth="520.0" prefHeight="520.0" prefWidth="436.0" spacing="18">

                <StackPane prefHeight="200.0" prefWidth="360.0" styleClass="image-card">
                    <Label fx:id="imagePlaceholderLabel" styleClass="image-placeholder" text="Ảnh sản phẩm" />
                    <ImageView fx:id="productImageView" fitHeight="236.0" fitWidth="322.0" preserveRatio="true" smooth="true" />
                </StackPane>

                <VBox prefHeight="145.0" prefWidth="432.0" spacing="10" styleClass="info-card">
                    <Label fx:id="nameLabel" styleClass="product-name" text="Product Name" />
                    <Label fx:id="categoryLabel" styleClass="muted-text" text="Category" />
                    <Separator />
                    <Label styleClass="section-label" text="Mô tả sản phẩm" />
                    <Label fx:id="descriptionLabel" styleClass="description-text" text="Description" wrapText="true" />
                </VBox>
                <VBox prefHeight="340" prefWidth="520" spacing="10" styleClass="chart-card">
                    <Label styleClass="card-title" text="Biểu đồ giá realtime" />

                    <LineChart fx:id="priceHistoryChart" animated="false" createSymbols="true" legendVisible="false" prefHeight="265.0" prefWidth="438.0">
                        <xAxis>
                            <NumberAxis fx:id="priceChartXAxis" forceZeroInRange="false" label="Thời gian" />
                        </xAxis>
                        <yAxis>
                            <NumberAxis fx:id="priceChartYAxis" forceZeroInRange="false" label="Giá" />
                        </yAxis>
                    </LineChart>
                </VBox>

            </VBox>

            <!-- RIGHT PANEL -->
            <VBox maxWidth="760" prefWidth="760" spacing="18" stylesheets="@../css/bidding-view.css">

                <HBox alignment="TOP_LEFT" spacing="18">

                    <!-- CỘT 1: Giá hiện tại + Người dẫn đầu -->
                    <VBox prefWidth="210" spacing="18">
                        <VBox maxWidth="Infinity" prefHeight="110" spacing="8" styleClass="stat-card">
                            <Label styleClass="stat-label" text="Giá hiện tại" />
                            <Label fx:id="currentPriceLabel" styleClass="main-price" text="0" />
                        </VBox>

                        <VBox maxWidth="Infinity" prefHeight="90" spacing="8" styleClass="info-card-small">
                            <Label styleClass="stat-label" text="Người dẫn đầu" />
                            <Label fx:id="leaderLabel" styleClass="stat-value" text="None" />
                        </VBox>
                    </VBox>

                    <!-- CỘT 2: Thời gian + Bước giá/Số lượt bid -->
                    <VBox prefWidth="260" spacing="18">
                        <VBox maxWidth="Infinity" prefHeight="110" spacing="8" styleClass="stat-card">
                            <Label styleClass="stat-label" text="Thời gian còn lại" />
                            <Label fx:id="timeLeftLabel" styleClass="countdown" text="00:00:00" />
                        </VBox>

                        <HBox spacing="18">
                            <VBox prefHeight="90" spacing="8" styleClass="stat-card" HBox.hgrow="ALWAYS">
                                <Label styleClass="stat-label" text="Bước giá" />
                                <Label fx:id="minIncrementLabel" styleClass="stat-value" text="0" />
                            </VBox>

                            <VBox prefHeight="90" spacing="8" styleClass="stat-card" HBox.hgrow="ALWAYS">
                                <Label styleClass="stat-label" text="Số lượt bid" />
                                <Label fx:id="bidCountLabel" styleClass="stat-value" text="0 bids" />
                            </VBox>
                        </HBox>
                    </VBox>

                    <!-- CỘT 3: Đấu giá tự động -->
                    <StackPane maxHeight="218" maxWidth="240" minWidth="240" prefHeight="218" prefWidth="240" styleClass="auto-bid-wrapper">
                        <VBox alignment="TOP_CENTER" spacing="8" styleClass="auto-bid-panel" StackPane.alignment="CENTER">

                            <Label alignment="CENTER" maxWidth="Infinity" styleClass="auto-bid-title" text="Đấu giá tự động" />

                            <VBox maxWidth="Infinity" spacing="4">
                                <Label styleClass="stat-label" text="Bước giá" />
                                <TextField fx:id="autoBidIncrementField" maxWidth="Infinity" promptText="Nhập bước giá" styleClass="auto-bid-input" />
                            </VBox>

                            <VBox maxWidth="Infinity" spacing="4">
                                <Label styleClass="stat-label" text="Số tiền tối đa" />
                                <TextField fx:id="autoBidMaxAmountField" maxWidth="Infinity" promptText="Nhập số tiền tối đa" styleClass="auto-bid-input" />
                            </VBox>

                            <HBox alignment="CENTER" maxWidth="Infinity" spacing="8">
                                <Button fx:id="enableAutoBidButton" maxWidth="Infinity" onAction="#handleEnableAutoBid" styleClass="auto-bid-enable-button" text="Bật" HBox.hgrow="ALWAYS" />

                                <Button fx:id="disableAutoBidButton" maxWidth="Infinity" onAction="#handleDisableAutoBid" styleClass="auto-bid-disable-button" text="Tắt" HBox.hgrow="ALWAYS" />
                            </HBox>
                        </VBox>
                    </StackPane>

                </HBox>

                <VBox spacing="14" styleClass="bid-card">
                    <Label styleClass="card-title" text="Đặt giá của bạn" />

                    <HBox alignment="CENTER_LEFT" spacing="12">
                        <TextField fx:id="bidAmountField" prefWidth="360" promptText="Nhập giá cao hơn giá hiện tại" styleClass="bid-input" />
                        <Label styleClass="currency-label" text="VND" />
                        <Button onAction="#handlePlaceBid" styleClass="primary-button" text="Đặt giá" />
                    </HBox>

                    <Label fx:id="messageLabel" styleClass="message-label" text="" />
                </VBox>

                <VBox prefWidth="749.0" spacing="12" styleClass="history-card" VBox.vgrow="ALWAYS">
                    <Label styleClass="card-title" text="Lịch sử đấu giá" />

                    <TableView fx:id="bidTable" prefHeight="270" prefWidth="704.0" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="indexColumn" prefWidth="70" sortable="false" text="STT" />
                            <TableColumn fx:id="bidderColumn" prefWidth="220" text="Người đấu" />
                            <TableColumn fx:id="amountColumn" prefWidth="220" text="Giá đấu" />
                            <TableColumn fx:id="timeColumn" prefWidth="260" text="Thời gian" />
                        </columns>
                    </TableView>
                </VBox>

            </VBox>

        </HBox>
    </center>

</BorderPane>
