<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="14"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="client.controller.AddProductController"
      alignment="TOP_LEFT"
      prefWidth="500"
      prefHeight="600"
      style="-fx-background-color: white; -fx-padding: 25;">

    <children>
        <Label text="Thêm sản phẩm mới"
               style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #111827;" />

        <Label text="Tên sản phẩm"/>
        <TextField fx:id="nameField" promptText="Nhập tên sản phẩm"/>

        <Label text="Danh mục"/>
        <TextField fx:id="categoryField" promptText="Ví dụ: ELECTRONICS"/>

        <Label text="Mô tả"/>
        <TextArea fx:id="descriptionField" promptText="Nhập mô tả sản phẩm" prefHeight="100"/>

        <Label text="Giá khởi điểm"/>
        <TextField fx:id="priceField" promptText="Ví dụ: 2500"/>

        <Label text="Ngày bắt đầu"/>
        <DatePicker fx:id="startDatePicker"/>

        <Label text="Ngày kết thúc"/>
        <DatePicker fx:id="endDatePicker"/>

        <HBox spacing="12">
            <children>
                <Button text="Lưu" onAction="#handleSave"
                        style="-fx-background-color: #4f46e5; -fx-text-fill: white; -fx-font-weight: bold;"/>
                <Button text="Hủy" onAction="#handleCancel"
                        style="-fx-background-color: #e5e7eb; -fx-font-weight: bold;"/>
            </children>
        </HBox>
    </children>
</VBox>