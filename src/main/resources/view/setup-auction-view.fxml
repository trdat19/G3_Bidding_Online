<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="760.0" prefWidth="720.0" stylesheets="@../css/setup-auction-view.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="client.controller.SetupAuctionViewController">

    <children>

        <VBox alignment="TOP_CENTER" spacing="28" styleClass="root-container" AnchorPane.bottomAnchor="0" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0" AnchorPane.topAnchor="0">

            <padding>
                <Insets bottom="36" left="36" right="36" top="36" />
            </padding>

            <!-- HEADER -->
            <VBox alignment="CENTER" spacing="8">

                <Label styleClass="form-title" text="Thiết lập phiên đấu giá" />

                <Label styleClass="form-subtitle" text="Nhập thông tin đấu giá sau khi admin đã duyệt" />

            </VBox>

            <!-- MAIN CARD -->
            <VBox maxWidth="620" spacing="24" styleClass="form-card">

                <padding>
                    <Insets bottom="32" left="32" right="32" top="32" />
                </padding>

                <!-- PRODUCT INFO -->
                <VBox spacing="8">

                    <Label styleClass="section-title" text="Thông tin sản phẩm" />

                    <VBox spacing="6" styleClass="info-box">

                        <Label fx:id="productNameLabel" styleClass="product-name" text="Tên sản phẩm" />

                        <Label fx:id="productCategoryLabel" styleClass="product-category" text="Danh mục" />

                    </VBox>

                </VBox>

                <!-- START PRICE -->
                <VBox spacing="10">

                    <Label styleClass="section-label" text="Giá khởi điểm" />

                    <TextField fx:id="startPriceField" promptText="Ví dụ: 2000" />

                </VBox>

                <!-- BID COUNT -->
                <VBox spacing="10">

                    <Label styleClass="section-label" text="Bid Count" />

                    <Spinner fx:id="minIncrementSpinner" editable="true" prefHeight="46" />

                </VBox>

                <!-- START TIME -->
                <VBox spacing="12">

                    <Label styleClass="section-label" text="Thời gian bắt đầu" />

                    <HBox alignment="CENTER_LEFT" spacing="14">

                        <DatePicker fx:id="startDatePicker" HBox.hgrow="ALWAYS" />

                        <ComboBox fx:id="startHourBox" prefWidth="90" />

                        <ComboBox fx:id="startMinuteBox" prefWidth="90" />

                    </HBox>

                </VBox>

                <!-- END TIME -->
                <VBox spacing="12">

                    <Label styleClass="section-label" text="Thời gian kết thúc" />

                    <HBox alignment="CENTER_LEFT" spacing="14">

                        <DatePicker fx:id="endDatePicker" HBox.hgrow="ALWAYS" />

                        <ComboBox fx:id="endHourBox" prefWidth="90" />

                        <ComboBox fx:id="endMinuteBox" prefWidth="90" />

                    </HBox>

                </VBox>

                <!-- INFO BOX -->
                <HBox alignment="CENTER_LEFT" spacing="12" styleClass="notice-box">

                    <Label styleClass="notice-icon" text="ℹ" />

                    <VBox spacing="4">

                        <Label styleClass="notice-title" text="Sau khi lưu, sản phẩm sẽ gửi yêu cầu cho Admin duyệt" />

                        <Label styleClass="notice-desc" text="Trạng thái sản phẩm sẽ chuyển sang OPEN khi Admin chấp nhận" />

                    </VBox>

                </HBox>

                <!-- ERROR -->
                <Label fx:id="errorLabel" styleClass="error-label" />

                <!-- BUTTONS -->
                <HBox alignment="CENTER_RIGHT" spacing="14">

                    <Button onAction="#handleCancel" styleClass="cancel-button" text="Hủy" />

                    <Button onAction="#handleSave" styleClass="save-button" text="Gửi yêu cầu" />

                </HBox>

            </VBox>

        </VBox>

    </children>

</AnchorPane>
