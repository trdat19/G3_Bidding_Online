<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox prefWidth="330.0" spacing="16.0" styleClass="auction-class" xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/17.0.12" fx:controller="client.controller.BidderDashboardController">

    <children>
        <StackPane prefHeight="210.0" prefWidth="200.0" styleClass="image-box">
            <children>
                <Label fx:id="categoryLabel" styleClass="category-badge" text="CATEGORY" StackPane.alignment="TOP_LEFT" />
                <Label fx:id="imagePlaceholderLabel" styleClass="image-placeholder" text="Image" />
            </children>
        </StackPane>

        <VBox spacing="8">
            <children>
                <Label fx:id="titleLabel" styleClass="item-title" text="Tên sản phẩm" />
                <Label fx:id="descriptionLabel" styleClass="item-desc" text="Mô tả sản phẩm" />
            </children>
        </VBox>

        <Separator />

        <HBox>
            <children>
                <VBox spacing="4">
                    <children>
                        <Label styleClass="meta-label" text="GIÁ HIỆN TẠI" />
                        <Label fx:id="priceLabel" text="\$">
                            <font>
                                <Font size="22.0" />
                            </font>
                        </Label>
                    </children>
                </VBox>

                <Region HBox.hgrow="ALWAYS" />

                <VBox alignment="CENTER_RIGHT" spacing="4">
                    <children>
                        <Label styleClass="meta-label" text="KẾT THÚC TRONG" />
                        <Label fx:id="timeLabel" styleClass="time-label" text="0:00" />
                    </children>
                </VBox>
            </children>
        </HBox>

        <Button onAction="#viewDetail" styleClass="detail-button" text="Xem chi tiết" />
    </children>
</VBox>
