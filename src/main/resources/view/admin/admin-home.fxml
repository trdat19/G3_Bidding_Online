<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<?import javafx.scene.layout.Region?>
<VBox xmlns:fx="http://javafx.com/fxml" spacing="20" styleClass="page" fx:controller="client.controller.AdminHomeController">
    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <HBox spacing="20">
        <VBox styleClass="stat-card" prefWidth="180">
            <Label fx:id="totalUsersLabel" text="0" styleClass="stat-number"/>
            <Label text="Tổng người dùng"/>
        </VBox>

        <VBox styleClass="stat-card" prefWidth="180">
            <Label fx:id="runningAuctionsLabel" text="0" styleClass="stat-number"/>
            <Label text="Phiên đang diễn ra"/>
        </VBox>

        <VBox styleClass="stat-card" prefWidth="180">
            <Label fx:id="finishedAuctionsLabel" text="0" styleClass="stat-number"/>
            <Label text="Phiên đã kết thúc"/>
        </VBox>

        <VBox styleClass="stat-card" prefWidth="180">
            <Label fx:id="totalProductsLabel" text="0" styleClass="stat-number"/>
            <Label text="Sản phẩm"/>
        </VBox>
    </HBox>

    <HBox spacing="20" VBox.vgrow="ALWAYS">
        <VBox styleClass="dashboard-card" spacing="14" HBox.hgrow="ALWAYS">
            <Label text="Công việc quản trị" styleClass="section-title"/>

            <HBox styleClass="focus-row" spacing="12">
                <Label text="Yêu cầu duyệt" styleClass="focus-label"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label text="Duyệt sản phẩm người bán gửi lên" styleClass="muted-text"/>
            </HBox>

            <HBox styleClass="focus-row" spacing="12">
                <Label text="Phiên đấu giá" styleClass="focus-label"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label text="Theo dõi các phiên đang chạy" styleClass="muted-text"/>
            </HBox>

            <HBox styleClass="focus-row" spacing="12">
                <Label text="Người dùng" styleClass="focus-label"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label text="Quản lý trạng thái tài khoản" styleClass="muted-text"/>
            </HBox>

            <HBox styleClass="focus-row" spacing="12">
                <Label text="Sản phẩm" styleClass="focus-label"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label text="Theo dõi sản phẩm trong hệ thống" styleClass="muted-text"/>
            </HBox>
        </VBox>

        <VBox styleClass="dashboard-card" spacing="14" prefWidth="360">
            <Label text="Tổng quan phiên đấu giá" styleClass="section-title"/>

            <HBox styleClass="summary-row">
                <Label text="Phiên đang diễn ra"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id = "runningAuctions" text="0" styleClass="summary-number"/>
            </HBox>

            <HBox styleClass="summary-row">
                <Label text="Phiên đang chờ duyệt"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id = "preparingAuctions" text="6" styleClass="summary-number"/>
            </HBox>

            <HBox styleClass="summary-row">
                <Label text="Phiên đã kết thúc"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id = "finishedAuctions" text="54" styleClass="summary-number"/>
            </HBox>
        </VBox>
    </HBox>

    <VBox styleClass="dashboard-card" spacing="12">
        <Label text="Tóm tắt quản trị" styleClass="section-title"/>
        <Label text="Sử dụng menu bên trái để duyệt yêu cầu, quản lý người dùng, theo dõi đấu giá và xem báo cáo hệ thống" styleClass="muted-text"/>
    </VBox>
</VBox>