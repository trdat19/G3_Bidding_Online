<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns:fx="http://javafx.com/fxml" spacing="18" styleClass="page">
    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <HBox alignment="CENTER_LEFT" spacing="12">
        <Label text="User Management" styleClass="page-title"/>
        <Region HBox.hgrow="ALWAYS"/>
        <TextField promptText="Search user..." prefWidth="240"/>
        <Button text="Refresh" styleClass="primary-btn"/>
    </HBox>

    <TableView fx:id="userTable" prefHeight="500">
        <columns>
            <TableColumn text="User ID" prefWidth="120"/>
            <TableColumn text="Username" prefWidth="220"/>
            <TableColumn text="Role" prefWidth="150"/>
            <TableColumn text="Status" prefWidth="150"/>
            <TableColumn text="Created At" prefWidth="180"/>
            <TableColumn text="Action" prefWidth="160"/>
        </columns>
    </TableView>
</VBox>
