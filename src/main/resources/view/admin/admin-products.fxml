<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="client.controller.AdminProductsController"
      spacing="18"
      styleClass="page">
    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <HBox alignment="CENTER_LEFT" spacing="12">
        <Label text="Product Management" styleClass="page-title"/>
        <Region HBox.hgrow="ALWAYS"/>
        <TextField fx:id="searchField"
                   promptText="Search product..."
                   prefWidth="220"/>
        <ComboBox fx:id="categoryFilterBox"
                  promptText="Category"
                  prefWidth="140"/>
        <ComboBox fx:id="statusFilterBox"
                  promptText="Status"
                  prefWidth="150"/>
        <Button text="Refresh"
                styleClass="primary-btn"
                onAction="#handleRefresh"/>
    </HBox>

    <TableView fx:id="productTable" prefHeight="500">
        <columns>
            <TableColumn fx:id="idColumn"
                         text="ID sản phẩm"
                         prefWidth="100"/>
            <TableColumn fx:id="nameColumn"
                         text="Tên sản phẩm"
                         prefWidth="190"/>
            <TableColumn fx:id="categoryColumn"
                         text="Danh mục"
                         prefWidth="130"/>
            <TableColumn fx:id="sellerColumn"
                         text="Người bán"
                         prefWidth="150"/>
            <TableColumn fx:id="startPriceColumn"
                         text="Giá khởi điểm"
                         prefWidth="130"/>
            <TableColumn fx:id="currentPriceColumn"
                         text="Giá hiện tại"
                         prefWidth="130"/>
            <TableColumn fx:id="statusColumn"
                         text="Trạng thái"
                         prefWidth="150"/>
            <TableColumn fx:id="createdAtColumn"
                         text="Ngày tạo"
                         prefWidth="160"/>
        </columns>
    </TableView>
</VBox>