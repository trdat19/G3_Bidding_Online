<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox prefHeight="390.0" prefWidth="460.0" spacing="16.0" styleClass="wallet-popup-root" stylesheets="@../css/bidder-dashboard.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="client.controller.WalletPopupController">
    <padding>
        <Insets bottom="24.0" left="24.0" right="24.0" top="24.0" />
    </padding>
    <children>
        <HBox alignment="CENTER_LEFT" spacing="12.0">
            <children>
                <Label styleClass="wallet-popup-icon" text="💳" />
                <VBox spacing="2.0" HBox.hgrow="ALWAYS">
                    <children>
                        <Label styleClass="wallet-popup-title" text="Ví của tôi" />
                        <Label styleClass="wallet-popup-subtitle" text="Nạp tiền để tham gia các phiên đấu giá." />
                    </children>
                </VBox>
            </children>
        </HBox>

        <VBox spacing="6.0" styleClass="wallet-balance-card">
            <children>
                <Label styleClass="wallet-title" text="SỐ DƯ HIỆN TẠI" />
                <Label fx:id="walletBalanceLabel" styleClass="wallet-balance" text="\$0.00" />
            </children>
        </VBox>

        <Label styleClass="wallet-title" text="NẠP NHANH" />
        <HBox spacing="10.0">
            <children>
                <Button mnemonicParsing="false" onAction="#handleQuickDeposit50" styleClass="quick-amount-button" text="\$50" />
                <Button mnemonicParsing="false" onAction="#handleQuickDeposit100" styleClass="quick-amount-button" text="\$100" />
                <Button mnemonicParsing="false" onAction="#handleQuickDeposit500" styleClass="quick-amount-button" text="\$500" />
                <Button mnemonicParsing="false" onAction="#handleQuickDeposit1000" styleClass="quick-amount-button" text="\$1000" />
            </children>
        </HBox>

        <TextField fx:id="depositAmountField" maxWidth="Infinity" promptText="Nhập số tiền muốn nạp" styleClass="deposit-field" />
        <Label fx:id="walletMessageLabel" styleClass="wallet-message" text="Chọn mức nạp nhanh hoặc nhập số tiền." wrapText="true" />

        <Region VBox.vgrow="ALWAYS" />

        <HBox alignment="CENTER_RIGHT" spacing="10.0">
            <children>
                <Button mnemonicParsing="false" onAction="#handleDeposit" styleClass="deposit-button" text="Nạp tiền" />
                <Button mnemonicParsing="false" onAction="#handleClose" styleClass="secondary-button" text="Đóng" />
            </children>
        </HBox>
    </children>
</VBox>