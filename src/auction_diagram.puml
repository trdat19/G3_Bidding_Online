' ================= CLIENT RELATIONS =================

MainApplication --> ClientLauncher
MainApplication --> LoginController
MainApplication --> RegisterFormController
MainApplication --> BidderDashboardController
MainApplication --> SellerDashboardController
MainApplication --> AdminDashboardController

LoginController --> ClientNetworkService
RegisterFormController --> ClientNetworkService
AuctionDetailController --> ClientNetworkService
BiddingViewController --> ClientNetworkService
AddProductController --> ItemService
EditProductController --> ItemService

ClientNetworkService --> BaseRequest
ClientNetworkService --> BaseResponse
ClientNetworkService --> ClientSession
ClientNetworkService --> SocketServer : socket

ClientSession --> UserDTO
ClientSessionState --> ClientSession
StageUtils --> MainApplication

' ================= SERVER CONTROLLER -> SERVICE =================

AuthServerController --> AuthService
AdminServerController --> AuditService
AdminServerController --> UserService
AuctionServerController --> AuctionService
BidServerController --> BidService
SellerServerController --> ItemService_Server
WalletServerController --> WalletService
AutoBidController --> AutoBidService

' ================= SERVER SERVICE -> DAO =================

AuthService --> UserDAO
UserService --> UserDAO
AuctionService --> AuctionDAO
AuctionService --> ItemDAO
BidService --> BidDAO
BidService --> AuctionDAO
AutoBidService --> AutoBidRuleDAO
ItemService_Server --> ItemDAO
WalletService --> UserDAO
AuditService --> AuctionDAO
RealtimeEventService --> RealtimePushServer

' ================= DAO -> DATABASE =================

AuctionDAO --> DBconnection
AutoBidRuleDAO --> DBconnection
BidDAO --> DBconnection
ItemDAO --> DBconnection
UserDAO --> DBconnection
TestUserDao --> DBconnection
TestConnection --> DBconnection

' ================= NETWORK =================

SocketServer --> ClientConnectionHandler
AuctionServer --> SocketServer
RealtimePushServer --> ClientConnectionHandler
ClientConnectionHandler --> RequestRouter
RequestRouter --> AuthServerController
RequestRouter --> AuctionServerController
RequestRouter --> BidServerController
RequestRouter --> AdminServerController
RequestRouter --> SellerServerController
RequestRouter --> WalletServerController

ClientConnectionHandler --> BaseRequest
ClientConnectionHandler --> BaseResponse

' ================= DOMAIN MODEL =================

Entity <|-- User
User <|-- Admin
User <|-- Bidder
User <|-- Seller

Entity <|-- Item_Server
Item_Server <|-- Art
Item_Server <|-- Electronics
Item_Server <|-- Vehicle

Auction --> Item_Server
Auction --> Bid
Auction --> AutoBidRule
Bid --> Bidder
BidTransaction --> Bid
AuctionManager --> Auction

' ================= FACTORY PATTERN =================

ItemFactory_Interface <|.. ArtFactory
ItemFactory_Interface <|.. ElectronicsFactory
ItemFactory_Interface <|.. VehicleFactory

ArtFactory --> Art
ElectronicsFactory --> Electronics
VehicleFactory --> Vehicle
ItemFactoryRegistry --> ItemFactory_Interface

' ================= DTO / ENUM =================

AuctionDTO --> AuctionStatus
ItemDTO --> ItemCategory
ItemDTO --> ItemStatus
UserDTO --> UserRole
UserDTO --> UserStatus
BaseRequest --> Action

AuctionService --> AuctionDTO
BidService --> BidDTO
ItemService_Server --> ItemDTO
UserService --> UserDTO

' ================= EXCEPTION HIERARCHY =================

AuctionException <|-- AuctionClosedException
AuctionException <|-- AuctionNotFoundException
AuctionException <|-- BidExceededLimitException
AuctionException <|-- BidTooLowException
AuctionException <|-- InsufficientBalanceException
AuctionException <|-- InvalidAuctionTimeException
AuctionException <|-- InvalidBidException

AuctionException_Server <|-- AuctionClosedException_Server
AuctionException_Server <|-- InvalidBidException_Server

' ================= SCHEDULER =================

AuctionScheduler --> AuctionService
AuctionScheduler --> AutoBidService
AuctionScheduler --> RealtimeEventService

@enduml