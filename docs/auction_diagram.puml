  package "dao" {
    class AuctionDAO {
      +insertAuction(auction: Auction) : boolean
      +findById(id: long) : Auction
      +getAllAuctions() : List<Auction>
      +getAllAuctionsBySellerId(sellerId: long) : List<Auction>
      +getAllAuctionsByItemId(itemId: long) : List<Auction>
      +getAllAuctionsByStatus(status: AuctionStatus) : List<Auction>
