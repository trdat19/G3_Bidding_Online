  }

  package "database" {
    class DBconnection {
      +getInstance() : DBconnection
      +getConnection() : Connection
    }

    class TestDBconection {
      +main(args: String[]) : void
    }
  }

  package "model" {
    abstract class Entity {
      +Entity()
      +Entity(id: Long)
      +getId() : Long
      +setId(id: Long) : void
      +getInfo() : String
      +toString() : String
    }

    package "core" {
      class Auction {
        +Auction()
        +Auction(itemId: Long, sellerId: Long, startPrice: BigDecimal, minIncrement: BigDecimal, buyNowPrice: BigDecimal, startTime: LocalDateTime, endTime: LocalDateTime)
        +open() : void
        +close() : void
        +isRunning() : boolean
        +add(bid: Bid) : void
        +getItemId() : Long
        +getSellerId() : Long
        +getStartPrice() : BigDecimal
        +getMaxPrice() : BigDecimal
        +getMinIncrement() : BigDecimal
        +getBuyNowPrice() : BigDecimal
        +getStatus() : AuctionStatus
        +getStartTime() : LocalDateTime
        +getEndTime() : LocalDateTime
        +getAllBids() : List<Bid>
        +getHighestBid() : Bid
        +setStatus(status: AuctionStatus) : void
        +getInfo() : String
      }

      class AuctionManager {
        +getInstance() : AuctionManager
        +placeBid(bidderId: Long, auctionId: Long, amount: BigDecimal) : void
      }

      class Bid {
        +Bid()
        +Bid(auctionId: Long, bidderId: Long, amount: BigDecimal)
        +getAuctionId() : Long
        +getBidderId() : Long
        +getAmount() : BigDecimal
        +getTimestamp() : LocalDateTime
        +setAuctionId(auctionId: Long) : void
        +setBidderId(bidderId: Long) : void
        +setAmount(amount: BigDecimal) : void
        +setTimestamp(timestamp: LocalDateTime) : void
        +getInfo() : String
        +isHigherThan(other: Bid) : boolean
      }

      class BidTransaction {
        +BidTransaction(bid: Bid)
        +execute(auction: Auction) : void
      }
    }

    package "item" {
      abstract class "Item" as ServerItem {
        +Item()
        +Item(nameItem: String, description: String, sellerId: Long, category: ItemCategory, statusItem: ItemStatus)
        +getNameItem() : String
        +getDescription() : String
        +getSellerId() : Long
        +getCategory() : ItemCategory
        +getStatusItem() : ItemStatus
        +getCreatedAtItem() : LocalDateTime
        +getImageUrl() : String
        +setNameItem(nameItem: String) : void
        +setDescription(description: String) : void
        +setSellerId(sellerId: Long) : void
        +setCategory(category: ItemCategory) : void
        +setStatusItem(statusItem: ItemStatus) : void
        +setCreatedAtItem(createdAtItem: LocalDateTime) : void
        +setImageUrl(imageUrl: String) : void
        +getInfo() : String
      }

      class Art {
        +Art()
        +Art(nameItem: String, description: String, sellerId: Long, statusItem: ItemStatus)
        +getArtist() : String
        +getYear() : int
        +getMaterial() : String
        +setArtist(artist: String) : void
        +setYear(year: int) : void
        +setMaterial(material: String) : void
        +getInfo() : String
      }

      class Electronics {
        +Electronics()
        +Electronics(nameItem: String, description: String, sellerId: Long, statusItem: ItemStatus)
        +getBrand() : String
        +getWarrantyMonth() : int
        +getModel() : String
        +getYear() : int
        +setBrand(brand: String) : void
        +setWarrantyMonth(warrantyMonth: int) : void
        +setModel(model: String) : void
        +setYear(year: int) : void
        +getInfo() : String
      }

      class Vehicle {
        +Vehicle()
        +Vehicle(nameItem: String, description: String, sellerId: Long, statusItem: ItemStatus)
        +getManufacturer() : String
        +getYear() : int
        +setManufacturer(manufacturer: String) : void
        +setYear(year: int) : void
        +getInfo() : String
      }

      class ServerItemFactory {
        +createItem(category: ItemCategory, name: String, description: String, sellerId: Long, status: ItemStatus) : ServerItem
      }

      package "factory" {
        interface ItemFactory {
          +createItem() : ServerItem
        }

        class ArtFactory {
          +createItem() : ServerItem
        }

        class ElectronicsFactory {
          +createItem() : ServerItem
        }

        class VehicleFactory {
          +createItem() : ServerItem
        }

        class ItemFactoryRegistry {
          +create(category: ItemCategory) : ServerItem
          +isSupported(category: ItemCategory) : boolean
        }
      }
    }

    package "user" {
      abstract class User {
        +User()
        +User(username: String, password: String, fullname: String, email: String)
        +getUsername() : String
        +getPassword() : String
        +getFullName() : String
        +getEmail() : String
        +getRole() : UserRole
        +getStatus() : UserStatus
        +getCreatedAt() : LocalDateTime
        +setUsername(username: String) : void
        +setPassword(password: String) : void
        +setFullname(fullname: String) : void
        +setEmail(email: String) : void
        +setRole(role: UserRole) : void
        +setStatus(status: UserStatus) : void
        +setCreatedAt(createdAt: LocalDateTime) : void
        +getInfo() : String
      }

      class Admin {
        +Admin()
        +Admin(username: String, password: String, fullname: String, email: String)
        +suspendUser(id: String) : void
        +viewReport() : void
        +getInfo() : String
      }

      class Bidder {
        +Bidder()
        +Bidder(username: String, password: String, fullName: String, email: String)
        +getBalance() : BigDecimal
        +getMaxBid() : BigDecimal
        +getBidIncrement() : BigDecimal
        +setBalance(balance: BigDecimal) : void
        +setMaxBid(maxBid: BigDecimal) : void
        +setBidIncrement(increment: BigDecimal) : void
        +getInfo() : String
        +deposit(amount: BigDecimal) : void
        +withdraw(amount: BigDecimal) : void
        +canAfford(amount: BigDecimal) : boolean
      }

      class Seller {
        +Seller()
        +Seller(username: String, password: String, fullname: String, email: String)
        +getInfo() : String
        +getTotalEarnings() : BigDecimal
        +setTotalEarnings(totalEarnings: BigDecimal) : void
      }
    }
  }

  package "network" {
    class AuctionServer

    class ClientConnectionHandler {
      +ClientConnectionHandler(socket: Socket)
      +run() : void
      +dispatch(request: BaseRequest) : void
      +sendResponse(response: Object) : void
      -closeConnection() : void
      +getUser() : User
      +setUser(user: User) : void
    }

    class RealtimePushServer {
      +pushToUser(userId: Long, event: BaseResponse) : void
      +pushToAuctionSubscribers(auctionId: Long, event: BaseResponse) : void
      +registerUser(userId: Long, handler: ClientConnectionHandler) : void
      +subscribeToAuction(auctionId: Long, handler: ClientConnectionHandler) : void
      +unsubscribeFromAuction(auctionId: Long, handler: ClientConnectionHandler) : void
      +removeConnection(handler: ClientConnectionHandler) : void
      +countOnlineUsers() : int
      +countRoomSubscribers(auctionId: int) : int
      +getOnlineUsers() : Set<Long>
      +printStatus() : void
    }

    class RequestRouter {
      -requireLogin(handler: ClientConnectionHandler) : void
      -requireRole(handler: ClientConnectionHandler, requiredRole: UserRole) : void
      +route(request: BaseRequest, handler: ClientConnectionHandler) : BaseResponse
    }

    class SocketSever {
      +start() : void
      -acceptLoop() : void
      -stop() : void
      +main(args: String[]) : void
    }
  }

  package "realtime" {
  }

  package "scheduler" {
    class AuctionScheduler {
      +getInstance() : AuctionScheduler
      +start() : void
      -checkAuctions() : void
      +stop() : void
    }
  }

  package "service" {
    class AuctionService {
      +getInstance() : AuctionService
      -toDTO(auction: Auction, item: ServerItem) : AuctionDTO
      +createAuction(data: Map<String, Object>) : AuctionDTO
      +cancelAuction(auctionId: Long) : boolean
      +startAuction(auctionId: Long) : boolean
      +finishAuction(auctionId: Long) : Map<String, Object>
      +extendAuction(auctionId: Long, extraSeconds: int) : boolean
      +getOpenAuctions() : List<AuctionDTO>
      +getAllAuctions() : List<AuctionDTO>
      +countAllAuctions() : long
      +getAuctionDetail(auctionId: Long) : AuctionDTO
      +getBidHistory(auctionId: Long) : List<BidDTO>
    }

    class AuditService {
      +logAction() : void
      +getLogs() : void
    }

    class AuthService {
      +getInstance() : AuthService
      +login(username: String, password: String) : User
      +register(username: String, password: String, fullname: String, email: String, role: UserRole) : User
      +logout(handler: ClientConnectionHandler) : void
      +verifySession() : void
    }

    class AutoBidService {
      +registerRule() : void
      +removeRule() : void
      +reactToIncomingBid() : void
    }

    class BidService {
      +getInstance() : BidService
      +placeBid(auctionId: Long, bidderId: Long, amount: BigDecimal) : boolean
      +isAmountValid(amount: BigDecimal, minBid: BigDecimal) : boolean
    }

    class "ItemService" as ServerItemService {
      +getInstance() : ServerItemService
      +createItem(sellerId: Long, data: Map<String, Object>) : ServerItem
      +updateItem(data: Map<String, Object>) : ServerItem
      +deleteItem(itemId: Long) : boolean
      +findBySeller(sellerId: Long) : List<ServerItem>
    }

    class RealtimeEventService {
      +publishNewBid() : void
      +publishExtension() : void
      +publishClosure() : void
    }

    class UserService {
      +getInstance() : UserService
      +findAllUsers() : List<User>
      +findUser(userId: Long) : User
      +countAllUsers() : long
      +changeStatus(userId: Long, status: UserStatus) : boolean
    }
  }
}

