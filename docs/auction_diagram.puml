      +existsOpenAuctionByItemId(itemId: long) : boolean
      +deleteAuction(idAuction: long) : boolean
      -mapResultSetToAuction(rs: ResultSet) : Auction
    }

    class BidDAO {
      +insertBid(bid: Bid) : boolean
      +findById(id: long) : Bid
      +getAllBids() : List<Bid>
