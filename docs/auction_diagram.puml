      +updateStatus(id: long, status: UserStatus) : boolean
      +deleteUser(id: long) : boolean
      +existsByUsername(username: String) : boolean
      +existsByEmail(email: String) : boolean
      -mapResultSetToUser(rs: ResultSet) : User
