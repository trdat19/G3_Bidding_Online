      +updateItem(item: ServerItem) : boolean
      +updateStatus(idItem: long, status: ItemStatus) : boolean
      +deleteItem(idItem: long) : boolean
      -mapResultSetToItem(rs: ResultSet) : ServerItem
    }

    class UserDAO {
      +insertUser(user: User) : boolean
      +findById(id: long) : User
      +findByUsername(username: String) : User
      +getAllUsers() : List<User>
