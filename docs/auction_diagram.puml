package "shared" {

  package "dto" {
    class AdminDashboardDTO

    package "common" {
      class AuctionDTO {
        +AuctionDTO()
        +AuctionDTO(id: Long, itemId: Long, itemName: String, ...)
        +getDisplayPrice() : BigDecimal
        +isOpen() : boolean
        +toString() : String
        +getters/setters()
      }

      class BidDTO {
        +BidDTO()
        +BidDTO(id: Long, auctionId: Long, bidderId: Long, bidderName: String, amount: BigDecimal, timestamp: LocalDateTime)
        +toString() : String
        +getters/setters()
      }

      class ItemDTO {
        +ItemDTO()
        +ItemDTO(id: Long, name: String, description: String, category: ItemCategory, ...)
        +ItemDTO(name: String, description: String, category: ItemCategory, ...)
        +toString() : String
        +getters/setters()
      }

      class UserDTO {
        +UserDTO()
        +UserDTO(id: Long, username: String, fullname: String, email: String, role: UserRole, status: UserStatus, createdAt: LocalDateTime)
