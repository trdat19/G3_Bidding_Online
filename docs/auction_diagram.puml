      BIDDER
      SELLER
    }

    enum UserStatus {
      ACTIVE
      BLOCKED
    }
  }

  package "event" {
  }

  package "exception" {
    class AuctionException {
      +AuctionException(message: String)
    }

    class AuctionClosedException {
      +AuctionClosedException()
    }

    class AuctionNotFoundException {
      +AuctionNotFoundException(auctionId: Long)
    }

    class BidExceededLimitException {
      +BidExceededLimitException(maxPrice: BigDecimal)
    }

    class BidTooLowException {
      +BidTooLowException(minBid: BigDecimal)
    }

    class InsufficientBalanceException {
      +InsufficientBalanceException(balance: BigDecimal)
    }

    class InvalidAuctionTimeException {
      +InvalidAuctionTimeException(now: LocalDateTime)
    }

    class InvalidBidException {
      +InvalidBidException(message: String)
