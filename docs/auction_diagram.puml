        +isActive() : boolean
        +toString() : String
        +getters/setters()
      }
    }

    package "request" {
      class BaseRequest {
        +BaseRequest(action: Action, data: Object)
        +getAction() : Action
        +getData() : Object
      }
    }

    package "response" {
      class BaseResponse {
        +BaseResponse(success: boolean, message: String, data: Object)
        +isSuccess() : boolean
        +getAction() : String
        +getData() : Object
        +getMessage() : String
        +setSuccess(success: boolean) : void
        +setAction(action: String) : void
        +setData(data: Object) : void
        +setMessage(message: String) : void
      }
    }
  }

  package "enums" {
    enum Action {
      LOGIN
      REGISTER
      LOGOUT
      CREATE_ITEM
      UPDATE_ITEM
      DELETE_ITEM
      SEND_CREATE_AUCTION_REQUEST
      PLACE_BID
      SUBSCRIBE_AUCTION
      UNSUBSCRIBE_AUCTION
      GET_USERS_LIST
      ENABLE_USER
      DISABLE_USER
      ACCEPT_CREATE_AUCTION_REQUEST
      EJECT_CREATE_AUCTION_REQUEST
      GET_BID_HISTORY
      GET_AUCTION_LIST
      GET_AUCTION_DETAILS
      GET_USER_PROFILE
      UPDATE_USER_PROFILE
      GET_LEADERBOARD
      GET_NOTIFICATIONS
    }

    enum AuctionStatus {
      PREPARING
      OPEN
      RUNNING
      FINISHED
      CLOSED
      CANCELLED
    }

    enum ItemCategory {
      ELECTRONICS
      ART
      VEHICLE
    }

    enum ItemStatus {
      PENDING
