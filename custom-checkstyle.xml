<?xml version="1.0"?>
<!DOCTYPE module PUBLIC
        "-//Checkstyle//DTD Checkstyle Configuration 1.3//EN"
        "https://checkstyle.org/dtds/configuration_1_3.dtd">

<!-- LEVEL TOÀN FILE -->
<module name="Checker">
    <module name="BeforeExecutionExclusionFileFilter">
        <property name="fileNamePattern" value="module-info\.java"/>
    </module>

    <!-- Cho phép file UTF-8 tránh lỗi Tiếng Việt bị vỡ chữ -->
    <property name="charset" value="UTF-8"/>

    <!-- Quy định thụt lề là space:
vào File -> Settings -> Editor -> Code Style -> bỏ tích Use tab character -> set tab size và indent là 4 -->
    <module name="FileTabCharacter"/>

    <!-- Độ dài dòng 140 thoáng hơn-->
    <module name="LineLength">
        <property name="max" value="140"/>
        <property name="ignorePattern" value="^import|^package"/>
    </module>

    <!-- Cho phép line dài hơn Google -->
    <module name="TreeWalker"> <!-- LEVEL TỪNG DÒNG -->

        <!-- ===== BASIC RULES ===== -->
        
        <!-- Indentation: thụt lề 4 spaces -->
        <module name="Indentation">
            <property name="basicOffset" value="4"/>
            <property name="lineWrappingIndentation" value="8"/>
        </module>

        <!-- Naming conventions (giữ lại vì quan trọng) -->
        <module name="TypeName"/>
        <module name="MethodName"/>
        <module name="ParameterName"/>
        <module name="LocalVariableName"/>
        <module name="MemberName"/>

        <!-- ===== OPTIONAL (nới lỏng) ===== -->

        <!-- Không bắt buộc Javadoc -->
        <!-- (Google mặc định bắt, mình tắt đi) -->
	<!-- (Nhưng đối với class có chức năng lớn, chuyên sâu, nên làm Javadoc để giải thích -->

        <!-- Cho phép thiếu final -->
        <!-- Không enforce visibility modifier everywhere -->

        <!-- ===== CLEAN CODE ===== -->

        <!-- Không cho import cái k dùng tới -->
        <module name="UnusedImports"/>

        <!-- Không cho import * -->
        <!-- <module name="AvoidStarImport"/> -->

        <!-- Require dấu {} -->
        <module name="NeedBraces"/>

        <!-- Tránh code khó đọc, khối rỗng-->
        <module name="EmptyBlock"/>

        <!-- Không cho nhiều biến trong 1 dòng -->
        <module name="MultipleVariableDeclarations"/>

        <!-- ===== FORMATTING ===== -->

	<!-- Bắt buộc space ở sau , -->
        <module name="WhitespaceAfter"/>
	<!-- Bắt buộc space quanh toán tử -->
        <module name="WhitespaceAround"/>

        <!-- Không ép xuống dòng quá gắt như Google -->
        <!-- <module name="NoLineWrap"/> -->


    </module>
</module>